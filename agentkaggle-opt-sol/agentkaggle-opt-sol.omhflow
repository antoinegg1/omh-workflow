    /lanes/C/meetingRecord: object
resources:
  - path: scripts/preflight-campaign.js
    kind: script
  - path: scripts/protected-files-baseline.js
    kind: script
  - path: scripts/protected-files-check.js
    kind: script
  - path: scripts/load-campaign-state.js
    kind: script
  - path: scripts/load-skills-and-wiki.js
    kind: script
  - path: scripts/lane-utils.js
    kind: script
  - path: scripts/campaign-controls.js
    kind: script
  - path: scripts/progressive-goals.js
    kind: script
  - path: scripts/submission-hash.js
    kind: script
  - path: scripts/sync-progressive-goals.js
    kind: script
  - path: scripts/run-js-workflow-script.js
    kind: script
  - path: scripts/select-forced-task-workload.js
    kind: script
  - path: scripts/task-selection-guard.js
    kind: script
  - path: scripts/compact-task-context.js
    kind: script
  - path: scripts/stint-budget-gate.js
    kind: script
  - path: scripts/prepare-plan-implementation.js
    kind: script
  - path: scripts/functional-review-gate.js
    kind: script
  - path: scripts/record-stint-candidate.js
    kind: script
  - path: scripts/direct-submission-gate.js
    kind: script
  - path: scripts/direct-loop-gate.js
    kind: script
  - path: scripts/restore-best-candidate.js
    kind: script
  - path: scripts/run-with-gpu-pool.js
    kind: script
  - path: scripts/implementation-precheck.js
    kind: script
  - path: scripts/validate-h800.js
    kind: script
  - path: scripts/optional-profile-h800.js
    kind: script
  - path: scripts/record-task-best.js
    kind: script
  - path: scripts/promote-and-update-leaderboard.js
    kind: script
  - path: scripts/task-local-loop-gate.js
    kind: script
  - path: scripts/next-task-or-finalize.js
    kind: script
  - path: scripts/release-worker-slot.js
    kind: script
  - path: scripts/time-budget-gate.js
    kind: script
  - path: prompts/select-task-workload.md
    kind: prompt
  - path: prompts/plan-implement.md
    kind: prompt
  - path: prompts/functional-review.md
    kind: prompt
  - path: prompts/correctness-repair.md
    kind: prompt
  - path: prompts/reward-hack-review.md
    kind: prompt
  - path: prompts/performance-review.md
    kind: prompt
  - path: prompts/revise-strategy.md
    kind: prompt
  - path: prompts/wiki-select-topic.md
    kind: prompt
  - path: prompts/wiki-search.md
    kind: prompt
  - path: scripts/wiki-write.js
    kind: script
  - path: scripts/wiki-loop-gate.js
    kind: script
  - path: prompts/meeting-brief.md
    kind: prompt
  - path: prompts/meeting-speaker.md
    kind: prompt
  - path: prompts/meeting-moderate.md
    kind: prompt
  - path: scripts/meeting-gate-sol.js
    kind: script
  - path: scripts/append-meeting-record.js
    kind: script
capabilities:
  tools:
    - bash
    - eval
    - task
    - web_search
    - fetch
  agents:
    - task
    - reviewer
nodes:
  - id: preflightCampaign
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/preflight-campaign.js
    writes:
      - /campaign
      - /workerPool
  - id: protectedFilesBaseline
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/protected-files-baseline.js
    reads:
      - /campaign
    writes:
      - /protectedFiles
  - id: loadCampaignState
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-campaign-state.js
    reads:
      - /campaign
      - /workerPool
    writes:
      - /campaign
      - /config
      - /leaderboard
  - id: loadSkillsAndWiki
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-skills-and-wiki.js
    reads:
      - /campaign
    writes:
      - /skills
      - /wiki
  - id: selectTaskWorkloadA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: coordinator
    workspaceAccess: write
    reads:
      - /campaign
      - /leaderboard
      - /wiki
      - /workerPool
    prompt:
      template:
        file: prompts/select-task-workload.md
        bindings:
          campaignTasks:
            state: /campaign/tasks
          campaignUpdates:
            state: /campaign/taskUpdates
          detailPaths:
            state: /campaign/detailPaths
          activeWorkerTasks:
            state: /campaign/taskUpdates/worker_pool
          selectionStatePath:
            inline: /lanes/A/selection
    writes:
      - /lanes/A/selection
  - id: selectForcedTaskWorkloadA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/select-forced-task-workload.js
    reads:
      - /campaign
      - /leaderboard
    writes:
      - /lanes/A/selection
  - id: taskSelectionGuardA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/task-selection-guard.js
    reads:
      - /lanes/A/selection
      - /workerPool
    writes:
      - /lanes/A/selectionGuard
      - /workerPool
  - id: loadCampaignStateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-campaign-state.js
    reads:
      - /campaign
      - /workerPool
    writes:
      - /campaign
      - /config
      - /leaderboard
  - id: compactTaskContextA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/compact-task-context.js
    reads:
      - /campaign
      - /lanes/A/selection
      - /lanes/A
    writes:
      - /lanes/A/taskContext
  - id: stintBudgetGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/stint-budget-gate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/selectionGuard
      - /lanes/A/localLoop
      - /lanes/A/directLoop
    writes:
      - /lanes/A/stintBudget
      - /lanes/A/roundBest
  - id: preparePlanImplementationA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/prepare-plan-implementation.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/directLoop
    writes:
      - /lanes/A/implementation
      - /lanes/A/implementationPrecheck
      - /lanes/A/functionalReview
      - /lanes/A/functionalReviewMeta
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
      - /lanes/A/directSubmission
      - /lanes/A/directLoop
      - /lanes/A/leaderboardUpdate
  - id: planImplementCandidateA
    type: agent
    timeoutMs: 57600000
    agent: task
    model:
      role: implementer
    workspaceAccess: write
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/functionalReview
    prompt:
      template:
        file: prompts/plan-implement.md
        bindings:
          mode:
            inline: round_start_or_direct_cycle
          taskContext:
            state: /lanes/A/taskContext
          stintBudget:
            state: /lanes/A/stintBudget
          functionalReview:
            state: /lanes/A/functionalReview
    writes:
      - /lanes/A/implementation
  - id: functionalReviewA
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: functionalReviewer
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementation
      - /lanes/A/implementationPrecheck
      - /lanes/A/stintBudget
    prompt:
      template:
        file: prompts/functional-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          implementation:
            state: /lanes/A/implementation
          precheck:
            state: /lanes/A/implementationPrecheck
          stintBudget:
            state: /lanes/A/stintBudget
    writes:
      - /lanes/A/functionalReview/verdict
    gates:
      - ready
      - improve
    fallbackVerdict: improve
  - id: functionalReviewGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/functional-review-gate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/functionalReview
      - /lanes/A/functionalReviewMeta
      - /lanes/A/stintBudget
    writes:
      - /lanes/A/functionalReviewMeta
  - id: planImplementReworkA
    type: agent
    timeoutMs: 14400000
    agent: task
    workspaceAccess: write
    model:
      role: implementer
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/functionalReview
    prompt:
      template:
        file: prompts/plan-implement.md
        bindings:
          mode:
            inline: functional_rework
          taskContext:
            state: /lanes/A/taskContext
          stintBudget:
            state: /lanes/A/stintBudget
          functionalReview:
            state: /lanes/A/functionalReview
    writes:
      - /lanes/A/implementation
  - id: implementationPrecheckA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/implementation-precheck.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementation
    writes:
      - /lanes/A/implementationPrecheck
  - id: protectedFilesCheckImplementationA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/protected-files-check.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
      - /protectedFiles
      - /workerPool
    writes:
      - /lanes/A/protectedFiles
  - id: validateH800A
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/validate-h800.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
    writes:
      - /lanes/A/validation
  - id: localCorrectnessRepairA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: repair
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
    prompt:
      template:
        file: prompts/correctness-repair.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          validation:
            state: /lanes/A/validation
          implementationStatePath:
            inline: /lanes/A/implementation
    writes:
      - /lanes/A/implementation
  - id: rewardHackReviewA
    type: review
    timeoutMs: 1800000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
      - /lanes/A/validation
    prompt:
      template:
        file: prompts/reward-hack-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          precheck:
            state: /lanes/A/implementationPrecheck
          validation:
            state: /lanes/A/validation
    writes:
      - /lanes/A/rewardHackReview/verdict
    gates:
      - pass
      - revise
      - fail
    fallbackVerdict: fail
  - id: recordStintCandidateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/record-stint-candidate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/implementation
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/stintCandidate
    writes:
      - /lanes/A/stintCandidate
  - id: directSubmissionGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/direct-submission-gate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/stintCandidate
      - /lanes/A/validation
      - /lanes/A/roundBest
    writes:
      - /lanes/A/directSubmission
  - id: directLoopGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/direct-loop-gate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
      - /lanes/A/leaderboardUpdate
    writes:
      - /lanes/A/directLoop
  - id: restoreRoundBestA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/restore-best-candidate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
    writes:
      - /lanes/A/roundBest
  - id: restoreStintBestA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/restore-best-candidate.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/stintBudget
    writes:
      - /lanes/A/roundBest
  - id: performanceReviewA
    type: agent
    timeoutMs: 1800000
    agent: task
    model:
      role: reviewer
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /leaderboard
    prompt:
      template:
        file: prompts/performance-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          validation:
            state: /lanes/A/validation
          rewardReview:
            state: /lanes/A/rewardHackReview
          leaderboard:
            state: /leaderboard
          performanceReviewStatePath:
            inline: /lanes/A/performanceReview
    writes:
      - /lanes/A/performanceReview
  - id: recordTaskBestA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/record-task-best.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
    writes:
      - /lanes/A/taskBestUpdate
  - id: optionalProfileH800A
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/optional-profile-h800.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/performanceReview
