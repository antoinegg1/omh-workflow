        file: prompts/wiki-select-topic.md
        bindings:
          campaign:
            state: /campaign
          wiki:
            state: /wiki
          laneTasks:
            inline: "See lane task contexts in reads; prefer an operator a worker lane is currently optimizing."
    writes:
      - /lanes/W/searchTopic
  - id: wikiSearchW
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: searchA
    workspaceAccess: write
    reads:
      - /lanes/W/searchTopic
      - /wiki
    prompt:
      template:
        file: prompts/wiki-search.md
        bindings:
          searcherName:
            inline: Searcher
          statePath:
            inline: /lanes/W/search
          searchTopic:
            state: /lanes/W/searchTopic
          wiki:
            state: /wiki
  - id: wikiWriteW
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/wiki-write.js
    waitFor:
      - wikiSearchW
    reads:
      - /lanes/W/searchTopic
      - /lanes/W/search
    writes:
      - /lanes/W/wikiWrite
      - /wiki
  - id: wikiLoopGateW
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/wiki-loop-gate.js
    reads:
      - /campaign
      - /lanes/A/taskContext
      - /lanes/B/taskContext
      - /lanes/C/taskContext
      - /lanes/D/taskContext
    writes:
      - /lanes/W/loop
  - id: meetingGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/meeting-gate-sol.js
    reads:
      - /lanes/A/localLoop
      - /lanes/A/taskContext
    writes:
      - /lanes/A/meeting
  - id: meetingBriefA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: coordinator
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/meeting
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/performanceReview
    prompt:
      template:
        file: prompts/meeting-brief.md
        bindings:
          meeting:
            state: /lanes/A/meeting
          taskContext:
            state: /lanes/A/taskContext
          validation:
            state: /lanes/A/validation
          performanceReview:
            state: /lanes/A/performanceReview
          briefStatePath:
            inline: /lanes/A/meetingBrief
    writes:
      - /lanes/A/meetingBrief
  - id: meetingCoordinatorA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: coordinator
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/meetingBrief
      - /lanes/A/taskContext
      - /leaderboard
      - /campaign
    prompt:
      template:
        file: prompts/meeting-speaker.md
        bindings:
          speakerName:
            inline: coordinator
          perspective:
            inline: campaign orchestration, validation strategy, and leaderboard impact
          roleCharter:
            inline: >-
              Outside meetings you are the CAMPAIGN COORDINATOR: you own the campaign-wide direction (runs/_campaign/direction.md is yours to write - your only file write scope), you select every lane's tasks, and you steward the finite remote submission budget. In this meeting speak for the global picture: whether this task still deserves this lane's time, and how the stall affects campaign priorities and budget. Observation A below is the leaderboard; Observation B is campaign progress. You may also read your own runs/_campaign/direction.md from the workspace.
          roleObservationA:
            state: /leaderboard
          roleObservationB:
            state: /campaign/progress
          brief:
            state: /lanes/A/meetingBrief
          taskContext:
            state: /lanes/A/taskContext
          speakerStatePath:
            inline: /lanes/A/meetingSpeakers/coordinator
    writes:
      - /lanes/A/meetingSpeakers/coordinator
  - id: meetingPlannerA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: planner
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/meetingBrief
      - /lanes/A/taskContext
      - /lanes/A/plan
      - /lanes/A/implementationPlan
    prompt:
      template:
        file: prompts/meeting-speaker.md
        bindings:
          speakerName:
            inline: planner
          perspective:
            inline: optimization strategy and the concrete implementation plan
          roleCharter:
            inline: >-
              Outside meetings you are this lane's PLANNER: you write the candidate plans (runs/<task>/docs/draft.md and plan.md are your only file write scope). In this meeting speak to strategy-level fixes: what the next plan should do differently and why. Observation A below is your current plan handoff; Observation B is the finalized implementation plan.
          roleObservationA:
            state: /lanes/A/plan
          roleObservationB:
            state: /lanes/A/implementationPlan
          brief:
            state: /lanes/A/meetingBrief
          taskContext:
            state: /lanes/A/taskContext
          speakerStatePath:
            inline: /lanes/A/meetingSpeakers/planner
    writes:
      - /lanes/A/meetingSpeakers/planner
  - id: meetingReviewerA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: reviewer
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/A/meetingBrief
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/performanceReview
    prompt:
      template:
        file: prompts/meeting-speaker.md
        bindings:
          speakerName:
            inline: reviewer
          perspective:
            inline: correctness risk, reward-hack risk, and whether the perf gain is real
          roleCharter:
            inline: >-
              Outside meetings you are the REVIEWER (plan review, reward-hack review, performance review) - a read-only role that never writes files. You judge correctness risk, reward-hack risk, and whether gains are real. In this meeting speak to why candidates failed review and what evidence would change your verdict. Observation A below is the latest validation result; Observation B is your latest performance review.
          roleObservationA:
            state: /lanes/A/validation
          roleObservationB:
            state: /lanes/A/performanceReview
          brief:
            state: /lanes/A/meetingBrief
          taskContext:
            state: /lanes/A/taskContext
          speakerStatePath:
            inline: /lanes/A/meetingSpeakers/reviewer
    writes:
      - /lanes/A/meetingSpeakers/reviewer
