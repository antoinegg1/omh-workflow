          brief:
            state: /lanes/C/meetingBrief
          taskContext:
            state: /lanes/C/taskContext
          speakerStatePath:
            inline: /lanes/C/meetingSpeakers/reviewer
    writes:
      - /lanes/C/meetingSpeakers/reviewer
  - id: meetingSearchAC
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: searchA
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/C/meetingBrief
      - /lanes/C/taskContext
      - /wiki
      - /lanes/W/searchTopic
    prompt:
      template:
        file: prompts/meeting-speaker.md
        bindings:
          speakerName:
            inline: Searcher A
          perspective:
            inline: web-sourced competition techniques and cross-checking against the wiki findings
          roleCharter:
            inline: >-
              Outside meetings you are SEARCHER A of the search lane: you research the open web (all public materials allowed) and maintain the shared wiki (wiki/** is your only file write scope). In this meeting bring outside evidence: what public sources suggest, what the wiki already covers, what you can research next. Observation A below is the wiki summary; Observation B is the search lane's current directive.
          roleObservationA:
            state: /wiki
          roleObservationB:
            state: /lanes/W/searchTopic
          brief:
            state: /lanes/C/meetingBrief
          taskContext:
            state: /lanes/C/taskContext
          speakerStatePath:
            inline: /lanes/C/meetingSpeakers/searchA
    writes:
      - /lanes/C/meetingSpeakers/searchA
  - id: meetingSearchBC
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: searchB
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    reads:
      - /lanes/C/meetingBrief
      - /lanes/C/taskContext
      - /wiki
      - /lanes/W/searchTopic
    prompt:
      template:
        file: prompts/meeting-speaker.md
        bindings:
          speakerName:
            inline: Searcher B
          perspective:
            inline: implementation failure modes and candidate patterns
          roleCharter:
            inline: >-
              Outside meetings you are SEARCHER B of the search lane: you research the open web (all public materials allowed) and maintain the shared wiki (wiki/** is your only file write scope). In this meeting bring outside evidence and failure modes seen elsewhere: what public sources suggest, what the wiki already covers, what you can research next. Observation A below is the wiki summary; Observation B is the search lane's current directive.
          roleObservationA:
            state: /wiki
          roleObservationB:
            state: /lanes/W/searchTopic
          brief:
            state: /lanes/C/meetingBrief
          taskContext:
            state: /lanes/C/taskContext
          speakerStatePath:
            inline: /lanes/C/meetingSpeakers/searchB
    writes:
      - /lanes/C/meetingSpeakers/searchB
  - id: meetingModerateC
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: coordinator
    workspaceAccess: read
    isolation:
      enabled: true
      apply: false
      merge: false
    waitFor:
      - meetingCoordinatorC
      - meetingPlannerC
      - meetingReviewerC
      - meetingSearchAC
      - meetingSearchBC
    reads:
      - /lanes/C/meetingBrief
      - /lanes/C/meetingSpeakers
    prompt:
      template:
        file: prompts/meeting-moderate.md
        bindings:
          brief:
            state: /lanes/C/meetingBrief
          coordinator:
            state: /lanes/C/meetingSpeakers/coordinator
          planner:
            state: /lanes/C/meetingSpeakers/planner
          reviewer:
            state: /lanes/C/meetingSpeakers/reviewer
          searchA:
            state: /lanes/C/meetingSpeakers/searchA
          searchB:
            state: /lanes/C/meetingSpeakers/searchB
          decisionStatePath:
            inline: /lanes/C/meetingDecision
    writes:
      - /lanes/C/meetingDecision
  - id: appendMeetingRecordC
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/append-meeting-record.js
    reads:
      - /lanes/C/meeting
      - /lanes/C/meetingBrief
      - /lanes/C/meetingSpeakers
      - /lanes/C/meetingDecision
      - /lanes/C/taskContext
    writes:
      - /lanes/C/meetingRecord
