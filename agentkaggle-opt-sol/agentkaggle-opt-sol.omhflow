    when: state.campaign.taskBatch.enabled != true && state.campaign.forcedTaskDir == "" && state.campaign.continue == true && state.config.workerLanes >= 4 && state.config.useCoordinator != false
  - from: compactTaskContextD
    to: stintBudgetGateD
  - from: stintBudgetGateD
    to: preparePlanImplementationD
    when: state.lanes.D.stintBudget.can_optimize == true
  - from: stintBudgetGateD
    to: restoreStintBestD
    when: state.lanes.D.stintBudget.can_optimize != true && state.lanes.D.stintBudget.finalization_expired != true
  - from: stintBudgetGateD
    to: releaseWorkerSlotD
    when: state.lanes.D.stintBudget.finalization_expired == true
  - from: preparePlanImplementationD
    to: planImplementCandidateD
  - from: planImplementCandidateD
    to: implementationPrecheckD
  - from: implementationPrecheckD
    to: protectedFilesCheckImplementationD
  - from: protectedFilesCheckImplementationD
    to: functionalReviewD
  - from: functionalReviewD
    to: functionalReviewGateD
  - from: functionalReviewGateD
    to: planImplementReworkD
    when: state.lanes.D.functionalReviewMeta.decision == "rework"
  - from: planImplementReworkD
    to: implementationPrecheckD
  - from: functionalReviewGateD
    to: validateH800D
    when: state.lanes.D.functionalReviewMeta.decision == "finalize"
  - from: validateH800D
    to: localCorrectnessRepairD
    when: state.lanes.D.validation.status != "passed" && state.lanes.D.validation.repair_exhausted != true
  - from: validateH800D
    to: releaseWorkerSlotD
    when: state.lanes.D.validation.repair_exhausted == true
  - from: localCorrectnessRepairD
    to: implementationPrecheckD
  - from: validateH800D
    to: rewardHackReviewD
    when: state.lanes.D.validation.status == "passed"
  - from: rewardHackReviewD
    to: recordStintCandidateD
  - from: recordStintCandidateD
    to: directSubmissionGateD
  - from: directSubmissionGateD
    to: promoteAndUpdateLeaderboardD
    when: state.lanes.D.directSubmission.authorized == true
  - from: directSubmissionGateD
    to: performanceReviewD
    when: state.lanes.D.directSubmission.authorized != true
  - from: promoteAndUpdateLeaderboardD
    to: directLoopGateD
    when: state.lanes.D.directSubmission.authorized == true
  - from: directLoopGateD
    to: compactTaskContextD
    when: state.lanes.D.directLoop.continue_inner == true
  - from: directLoopGateD
    to: taskLocalLoopGateD
    when: state.lanes.D.directLoop.continue_inner != true && state.lanes.D.directLoop.reached_new_milestone == true
  - from: directLoopGateD
    to: restoreRoundBestD
    when: state.lanes.D.directLoop.continue_inner != true && state.lanes.D.directLoop.reached_new_milestone != true
  - from: restoreRoundBestD
    to: validateH800D
  - from: restoreStintBestD
    to: validateH800D
  - from: performanceReviewD
    to: recordTaskBestD
  - from: recordTaskBestD
    to: optionalProfileH800D
  - from: optionalProfileH800D
    to: reviseStrategyD
  - from: reviseStrategyD
    to: protectedFilesCheckRevisionD
  - from: protectedFilesCheckRevisionD
    to: promoteAndUpdateLeaderboardD
  - from: promoteAndUpdateLeaderboardD
    to: taskLocalLoopGateD
    when: state.lanes.D.directSubmission.authorized != true
  - from: taskLocalLoopGateD
    to: compactTaskContextD
    when: state.lanes.D.localLoop.continueSameTask == true
  - from: taskLocalLoopGateD
    to: releaseWorkerSlotD
    when: state.lanes.D.localLoop.continueSameTask != true
  - from: releaseWorkerSlotD
    to: nextTaskOrFinalizeD
  - from: nextTaskOrFinalizeD
    to: timeBudgetGateD
  - from: timeBudgetGateD
    to: loadCampaignStateD
    when: state.campaign.continue == true
  - from: loadSkillsAndWiki
    to: wikiSelectTopicW
    when: state.campaign.continue == true && state.config.searchAgents >= 1
  - from: wikiSelectTopicW
    to: wikiSearchW
  - from: wikiSearchW
    to: wikiWriteW
  - from: wikiWriteW
    to: wikiLoopGateW
  - from: wikiLoopGateW
    to: wikiSelectTopicW
    when: state.campaign.continue == true
```
