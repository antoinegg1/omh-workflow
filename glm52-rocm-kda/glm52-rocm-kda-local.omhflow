    gates:
      - pass
      - reject
    fallbackVerdict: reject
  - id: validateAMDB
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        GLM52_KDA_LANE=B GLM52_KDA_TASK=routed-expert-gate-up-down GLM52_KDA_SUBMISSION=/home/lichangye/glm52-rocm-kda-tasks/routed-expert-gate-up-down/solution "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/validate-amd.js
    reads:
      - /campaign
      - /lanes/B/implementation
      - /lanes/B/implementReview
      - /lanes/B/rewardHackReview
      - /lanes/B/performanceReview
    writes:
      - /lanes/B/validateAMD
  - id: strictJudgeB
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        GLM52_KDA_LANE=B GLM52_KDA_TASK=routed-expert-gate-up-down GLM52_KDA_SUBMISSION=/home/lichangye/glm52-rocm-kda-tasks/routed-expert-gate-up-down/solution "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/strict-judge.js
    reads:
