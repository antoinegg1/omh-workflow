    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        GLM52_KDA_LANE=C GLM52_KDA_TASK=dsa-index-score GLM52_KDA_SUBMISSION=/home/lichangye/glm52-rocm-kda-tasks/dsa-index-score/solution "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/strict-judge.js
    reads:
