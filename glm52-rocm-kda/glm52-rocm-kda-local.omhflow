      - /lanes/C/rewardHackReview
      - /lanes/C/performanceReview
      - /lanes/C/validateAMD
    writes:
      - /lanes/C/strictJudge

  - id: wikiSearchA
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: searchA
    workspaceAccess: write
    reads:
      - /campaign
      - /wiki
    prompt:
      template:
        file: prompts/wiki-search.md
        bindings:
          searcherName:
            inline: searcher-a
          directive:
            inline: research
          reportPath:
            inline: wiki/.reports/searcher-a.json
    writes:
      - /lanes/W/searchA
  - id: wikiSearchB
    type: agent
    timeoutMs: 28800000
    agent: task
    model:
      role: searchB
    workspaceAccess: write
    reads:
      - /campaign
      - /wiki
    prompt:
      template:
        file: prompts/wiki-search.md
        bindings:
          searcherName:
            inline: searcher-b
          directive:
            inline: distill
          reportPath:
            inline: wiki/.reports/searcher-b.json
    writes:
      - /lanes/W/searchB
  - id: wikiWrite
    type: script
    script:
      language: sh
      inline: |-
        "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/wiki-write.js
    reads:
      - /campaign
      - /lanes/W/searchA
      - /lanes/W/searchB
    writes:
      - /lanes/W/wikiWrite
      - /wiki

edges:
  - from: preflightCampaign
    to: implementA
  - from: implementA
    to: implementReviewA
  - from: implementReviewA
    to: implementA
    when: state.lanes.A.implementReview.verdict == "improve"
  - from: implementReviewA
    to: rewardHackReviewA
    when: state.lanes.A.implementReview.verdict == "ready"
  - from: rewardHackReviewA
    to: implementA
    when: state.lanes.A.rewardHackReview.verdict == "reject"
  - from: rewardHackReviewA
    to: performanceReviewA
    when: state.lanes.A.rewardHackReview.verdict == "pass"
  - from: performanceReviewA
    to: implementA
    when: state.lanes.A.performanceReview.verdict == "reject"
  - from: performanceReviewA
    to: validateAMDA
    when: state.lanes.A.performanceReview.verdict == "pass"
  - from: validateAMDA
    to: strictJudgeA
    when: state.lanes.A.validateAMD.status == "passed"

  - from: preflightCampaign
    to: implementB
  - from: implementB
    to: implementReviewB
  - from: implementReviewB
    to: implementB
    when: state.lanes.B.implementReview.verdict == "improve"
  - from: implementReviewB
    to: rewardHackReviewB
    when: state.lanes.B.implementReview.verdict == "ready"
  - from: rewardHackReviewB
    to: implementB
    when: state.lanes.B.rewardHackReview.verdict == "reject"
  - from: rewardHackReviewB
    to: performanceReviewB
    when: state.lanes.B.rewardHackReview.verdict == "pass"
  - from: performanceReviewB
    to: implementB
    when: state.lanes.B.performanceReview.verdict == "reject"
  - from: performanceReviewB
    to: validateAMDB
    when: state.lanes.B.performanceReview.verdict == "pass"
  - from: validateAMDB
    to: strictJudgeB
    when: state.lanes.B.validateAMD.status == "passed"

  - from: preflightCampaign
    to: implementC
  - from: implementC
    to: implementReviewC
  - from: implementReviewC
    to: implementC
    when: state.lanes.C.implementReview.verdict == "improve"
  - from: implementReviewC
    to: rewardHackReviewC
    when: state.lanes.C.implementReview.verdict == "ready"
  - from: rewardHackReviewC
    to: implementC
    when: state.lanes.C.rewardHackReview.verdict == "reject"
  - from: rewardHackReviewC
    to: performanceReviewC
    when: state.lanes.C.rewardHackReview.verdict == "pass"
  - from: performanceReviewC
    to: implementC
    when: state.lanes.C.performanceReview.verdict == "reject"
  - from: performanceReviewC
    to: validateAMDC
    when: state.lanes.C.performanceReview.verdict == "pass"
  - from: validateAMDC
    to: strictJudgeC
    when: state.lanes.C.validateAMD.status == "passed"

  - from: preflightCampaign
    to: wikiSearchA
  - from: preflightCampaign
    to: wikiSearchB
  - from: wikiSearchA
    to: wikiWrite
  - from: wikiSearchB
    to: wikiWrite
```
