    prompt:
      template:
        file: prompts/implement-review.md
        bindings:
          lane:
            inline: B
          operatorId:
            inline: routed-expert-gate-up-down
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/routed-expert-gate-up-down
          implementation:
            state: /lanes/B/implementation
    writes:
