  - id: implementC
    type: agent
    timeoutMs: 57600000
    agent: task
    model:
      role: implementer
    workspaceAccess: write
    reads:
      - /campaign
      - /wiki
      - /lanes/C/implementReview
      - /lanes/C/rewardHackReview
      - /lanes/C/performanceReview
    prompt:
      template:
        file: prompts/implement.md
        bindings:
          lane:
            inline: C
          operatorId:
            inline: dsa-index-score
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/dsa-index-score
          review:
            state: /lanes/C/implementReview
          rewardHackReview:
            state: /lanes/C/rewardHackReview
          performanceReview:
            state: /lanes/C/performanceReview
    writes:
      - /lanes/C/implementation
  - id: implementReviewC
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /campaign
      - /wiki
      - /lanes/C/implementation
    prompt:
      template:
        file: prompts/implement-review.md
        bindings:
          lane:
            inline: C
          operatorId:
            inline: dsa-index-score
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/dsa-index-score
