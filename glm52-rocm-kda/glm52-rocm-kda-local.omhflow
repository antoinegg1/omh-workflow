---
name: glm52-rocm-kda-local
version: 1
schema: omhflow/v1
models:
  roles:
    implementer: infini/gpt-5.5:xhigh
    reviewer: infini/claude-opus-4-8:xhigh
    searchA: infini/gpt-5.5:xhigh
    searchB: infini/claude-opus-4-8:xhigh
  defaults:
    agent: implementer
    review: reviewer
  unavailable: fail
checkpoint:
  stopDeadlineMs: 300000
changePolicy:
  agentsCanPropose: true
  humansCanApprove: true
---
# GLM-5.2 ROCm KDA

```yaml workflow
stateSchema:
  version: 1
  shape:
    campaign: object
    config: object
    lanes: object
    wiki: object
    /lanes/A/implementation: object
    /lanes/A/implementReview: object
    /lanes/A/implementReview/verdict: string
    /lanes/A/rewardHackReview: object
    /lanes/A/rewardHackReview/verdict: string
    /lanes/A/performanceReview: object
    /lanes/A/performanceReview/verdict: string
    /lanes/A/validateAMD: object
    /lanes/A/validateAMD/status: string
    /lanes/A/formalTests: object
    /lanes/A/formalTests/latest: object
    /lanes/A/strictJudge: object
    /lanes/B/implementation: object
    /lanes/B/implementReview: object
    /lanes/B/implementReview/verdict: string
    /lanes/B/rewardHackReview: object
    /lanes/B/rewardHackReview/verdict: string
    /lanes/B/performanceReview: object
    /lanes/B/performanceReview/verdict: string
    /lanes/B/validateAMD: object
    /lanes/B/validateAMD/status: string
    /lanes/B/formalTests: object
    /lanes/B/formalTests/latest: object
    /lanes/B/strictJudge: object
    /lanes/C/implementation: object
    /lanes/C/implementReview: object
    /lanes/C/implementReview/verdict: string
    /lanes/C/rewardHackReview: object
    /lanes/C/rewardHackReview/verdict: string
    /lanes/C/performanceReview: object
    /lanes/C/performanceReview/verdict: string
    /lanes/C/validateAMD: object
    /lanes/C/validateAMD/status: string
    /lanes/C/formalTests: object
    /lanes/C/formalTests/latest: object
    /lanes/C/strictJudge: object
    /lanes/W/searchA: object
    /lanes/W/searchB: object
    /lanes/W/wikiWrite: object
resources:
  - path: scripts/run-js-workflow-script.js
    kind: script
  - path: scripts/preflight-campaign.js
    kind: script
  - path: scripts/validate-amd.js
    kind: script
  - path: scripts/strict-judge.js
    kind: script
  - path: scripts/wiki-write.js
    kind: script
  - path: prompts/implement.md
    kind: prompt
  - path: prompts/implement-review.md
    kind: prompt
  - path: prompts/reward-hack-review.md
    kind: prompt
  - path: prompts/performance-review.md
    kind: prompt
  - path: prompts/wiki-search.md
    kind: prompt
capabilities:
  tools:
    - bash
    - eval
    - web_search
    - fetch
  agents:
    - task
    - reviewer
nodes:
  - id: preflightCampaign
    type: script
    script:
      language: sh
      inline: |-
        "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/preflight-campaign.js
    writes:
      - /campaign
      - /config
      - /wiki

  - id: implementA
    type: agent
    timeoutMs: 57600000
    agent: task
    model:
      role: implementer
    workspaceAccess: write
    reads:
      - /campaign
      - /wiki
      - /lanes/A/implementReview
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
    prompt:
      template:
        file: prompts/implement.md
        bindings:
          lane:
            inline: A
          operatorId:
            inline: mla-prefill-attn
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn
          review:
            state: /lanes/A/implementReview
          rewardHackReview:
            state: /lanes/A/rewardHackReview
          performanceReview:
            state: /lanes/A/performanceReview
    writes:
      - /lanes/A/implementation
  - id: implementReviewA
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /campaign
      - /wiki
      - /lanes/A/implementation
    prompt:
      template:
        file: prompts/implement-review.md
        bindings:
          lane:
            inline: A
          operatorId:
            inline: mla-prefill-attn
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn
          implementation:
            state: /lanes/A/implementation
    writes:
      - /lanes/A/implementReview/verdict
    gates:
      - ready
      - improve
    fallbackVerdict: improve
  - id: rewardHackReviewA
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /campaign
      - /wiki
      - /lanes/A/implementation
      - /lanes/A/implementReview
    prompt:
      template:
        file: prompts/reward-hack-review.md
        bindings:
          lane:
            inline: A
          operatorId:
            inline: mla-prefill-attn
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn
          implementation:
            state: /lanes/A/implementation
          implementReview:
            state: /lanes/A/implementReview
    writes:
      - /lanes/A/rewardHackReview/verdict
    gates:
      - pass
      - reject
    fallbackVerdict: reject
  - id: performanceReviewA
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /campaign
      - /wiki
      - /lanes/A/implementation
      - /lanes/A/implementReview
      - /lanes/A/rewardHackReview
      - /lanes/A/formalTests
    prompt:
      template:
        file: prompts/performance-review.md
        bindings:
          lane:
            inline: A
          operatorId:
            inline: mla-prefill-attn
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn
          implementation:
            state: /lanes/A/implementation
          rewardHackReview:
            state: /lanes/A/rewardHackReview
          formalTests:
            state: /lanes/A/formalTests/latest
    writes:
      - /lanes/A/performanceReview/verdict
    gates:
      - pass
      - reject
    fallbackVerdict: reject
  - id: validateAMDA
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        GLM52_KDA_LANE=A GLM52_KDA_TASK=mla-prefill-attn GLM52_KDA_SUBMISSION=/home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn/solution "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/validate-amd.js
    reads:
      - /campaign
      - /lanes/A/implementation
      - /lanes/A/implementReview
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
    writes:
      - /lanes/A/validateAMD
  - id: strictJudgeA
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        GLM52_KDA_LANE=A GLM52_KDA_TASK=mla-prefill-attn GLM52_KDA_SUBMISSION=/home/lichangye/glm52-rocm-kda-tasks/mla-prefill-attn/solution "${BUN_BIN:-/home/lichangye/.bun/bin/bun}" "${OMP_WORKFLOW_RESOURCE_DIR:-/home/lichangye/omh-workflow/glm52-rocm-kda/glm52-rocm-kda}/scripts/run-js-workflow-script.js" scripts/strict-judge.js
    reads:
      - /campaign
      - /lanes/A/implementation
      - /lanes/A/implementReview
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
      - /lanes/A/validateAMD
    writes:
      - /lanes/A/strictJudge

  - id: implementB
    type: agent
    timeoutMs: 57600000
    agent: task
    model:
      role: implementer
    workspaceAccess: write
    reads:
      - /campaign
      - /wiki
      - /lanes/B/implementReview
      - /lanes/B/rewardHackReview
      - /lanes/B/performanceReview
    prompt:
      template:
        file: prompts/implement.md
        bindings:
          lane:
            inline: B
          operatorId:
            inline: routed-expert-gate-up-down
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/routed-expert-gate-up-down
          review:
            state: /lanes/B/implementReview
          rewardHackReview:
            state: /lanes/B/rewardHackReview
