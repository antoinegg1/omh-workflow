            inline: C
          operatorId:
            inline: dsa-index-score
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/dsa-index-score
          implementation:
            state: /lanes/C/implementation
          implementReview:
            state: /lanes/C/implementReview
    writes:
      - /lanes/C/rewardHackReview/verdict
    gates:
      - pass
      - reject
    fallbackVerdict: reject
  - id: performanceReviewC
    type: review
    timeoutMs: 3600000
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /campaign
      - /wiki
      - /lanes/C/implementation
      - /lanes/C/implementReview
      - /lanes/C/rewardHackReview
      - /lanes/C/formalTests
    prompt:
      template:
        file: prompts/performance-review.md
        bindings:
          lane:
            inline: C
          operatorId:
            inline: dsa-index-score
          taskDir:
            inline: /home/lichangye/glm52-rocm-kda-tasks/dsa-index-score
          implementation:
            state: /lanes/C/implementation
          rewardHackReview:
            state: /lanes/C/rewardHackReview
          formalTests:
            state: /lanes/C/formalTests/latest
    writes:
      - /lanes/C/performanceReview/verdict
    gates:
