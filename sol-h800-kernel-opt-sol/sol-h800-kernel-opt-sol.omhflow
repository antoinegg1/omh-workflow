    /lanes/B/validation/repair_exhausted: boolean
    /lanes/B/profile: object
    /lanes/B/rewardHackReview: object
    /lanes/B/performanceReview: object
    /lanes/B/revision: object
    /lanes/B/taskBestUpdate: object
    /lanes/B/leaderboardUpdate: object
    /lanes/B/localLoop: object
    /lanes/B/localLoop/continueSameTask: boolean
    /lanes/B/release: object
    /lanes/B/protectedFiles: object
    /lanes/C/selection: object
    /lanes/C/selectionGuard: object
    /lanes/C/selectionGuard/status: string
    /lanes/C/taskContext: object
    /lanes/C/plan: object
    /lanes/C/planReview: object
    /lanes/C/planReviewMeta: object
    /lanes/C/planReviewMeta/decision: string
    /lanes/C/implementationPlan: object
    /lanes/C/implementation: object
    /lanes/C/implementationPrecheck: object
    /lanes/C/validation: object
    /lanes/C/validation/status: string
    /lanes/C/validation/repair_exhausted: boolean
    /lanes/C/profile: object
    /lanes/C/rewardHackReview: object
    /lanes/C/performanceReview: object
