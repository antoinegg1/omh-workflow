edges:
  - from: preflightCampaign
    to: protectedFilesBaseline
  - from: protectedFilesBaseline
    to: loadCampaignState
  - from: loadCampaignState
    to: loadSkillsAndWiki
  - from: loadSkillsAndWiki
    to: selectForcedTaskWorkloadA
    when: (state.campaign.taskBatch.enabled == true || state.campaign.forcedTaskDir != "") && state.campaign.continue == true
  - from: loadSkillsAndWiki
    to: selectTaskWorkloadA
    when: state.campaign.taskBatch.enabled != true && state.campaign.forcedTaskDir == "" && state.campaign.continue == true
  - from: selectForcedTaskWorkloadA
    to: taskSelectionGuardA
  - from: selectTaskWorkloadA
    to: taskSelectionGuardA
  - from: taskSelectionGuardA
    to: compactTaskContextA
    when: state.lanes.A.selectionGuard.status == "acquired"
  - from: taskSelectionGuardA
    to: loadCampaignStateA
    when: state.lanes.A.selectionGuard.status == "duplicate"
  - from: loadCampaignStateA
    to: selectForcedTaskWorkloadA
    when: (state.campaign.taskBatch.enabled == true || state.campaign.forcedTaskDir != "") && state.campaign.continue == true
  - from: loadCampaignStateA
    to: selectTaskWorkloadA
    when: state.campaign.taskBatch.enabled != true && state.campaign.forcedTaskDir == "" && state.campaign.continue == true
  - from: compactTaskContextA
    to: resetSimplePlanStateA
  - from: resetSimplePlanStateA
    to: draftPlanA
  - from: draftPlanA
    to: planReviewCheckA
  - from: planReviewCheckA
    to: planReviewGateA
  - from: planReviewGateA
    to: revisePlanA
    when: state.lanes.A.planReviewMeta.decision == "revise"
  - from: revisePlanA
    to: planReviewCheckA
  - from: planReviewGateA
    to: finalizeImplementationPlanA
    when: state.lanes.A.planReviewMeta.decision == "finalize"
  - from: finalizeImplementationPlanA
    to: implementCandidateA
  - from: implementCandidateA
    to: implementationPrecheckA
  - from: implementationPrecheckA
    to: protectedFilesCheckImplementationA
  - from: protectedFilesCheckImplementationA
    to: validateH800A
  - from: validateH800A
    to: localCorrectnessRepairA
    when: state.lanes.A.validation.status != "passed" && state.lanes.A.validation.repair_exhausted != true
  - from: validateH800A
    to: releaseWorkerSlotA
    when: state.lanes.A.validation.repair_exhausted == true
  - from: localCorrectnessRepairA
    to: implementationPrecheckA
  - from: validateH800A
    to: rewardHackReviewA
    when: state.lanes.A.validation.status == "passed"
  - from: rewardHackReviewA
    to: performanceReviewA
  - from: performanceReviewA
    to: recordTaskBestA
  - from: recordTaskBestA
    to: optionalProfileH800A
  - from: optionalProfileH800A
    to: reviseStrategyA
  - from: reviseStrategyA
    to: protectedFilesCheckRevisionA
  - from: protectedFilesCheckRevisionA
    to: promoteAndUpdateLeaderboardA
  - from: promoteAndUpdateLeaderboardA
    to: taskLocalLoopGateA
  - from: taskLocalLoopGateA
    to: meetingGateA
    when: state.lanes.A.localLoop.continueSameTask == true
  - from: meetingGateA
    to: meetingBriefA
    when: state.lanes.A.meeting.required == true
  - from: meetingGateA
    to: compactTaskContextA
    when: state.lanes.A.meeting.required != true
  - from: meetingBriefA
    to: meetingCoordinatorA
  - from: meetingBriefA
    to: meetingPlannerA
  - from: meetingBriefA
    to: meetingReviewerA
  - from: meetingBriefA
    to: meetingGlmA
  - from: meetingBriefA
    to: meetingDeepseekA
  - from: meetingCoordinatorA
    to: meetingModerateA
  - from: meetingPlannerA
    to: meetingModerateA
  - from: meetingReviewerA
    to: meetingModerateA
  - from: meetingGlmA
    to: meetingModerateA
  - from: meetingDeepseekA
    to: meetingModerateA
  - from: meetingModerateA
    to: appendMeetingRecordA
  - from: appendMeetingRecordA
    to: compactTaskContextA
  - from: taskLocalLoopGateA
    to: releaseWorkerSlotA
    when: state.lanes.A.localLoop.continueSameTask != true
  - from: releaseWorkerSlotA
    to: nextTaskOrFinalizeA
  - from: nextTaskOrFinalizeA
    to: timeBudgetGateA
  - from: timeBudgetGateA
    to: loadCampaignStateA
    when: state.campaign.continue == true
  - from: loadSkillsAndWiki
    to: selectForcedTaskWorkloadB
    when: (state.campaign.taskBatch.enabled == true || state.campaign.forcedTaskDir != "") && state.campaign.continue == true
  - from: loadSkillsAndWiki
    to: selectTaskWorkloadB
