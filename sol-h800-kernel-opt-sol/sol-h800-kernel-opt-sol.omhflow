    /lanes/A/meetingRecord: object
    /lanes/B/meeting: object
    /lanes/B/meeting/required: boolean
    /lanes/B/meetingBrief: object
    /lanes/B/meetingSpeakers: object
    /lanes/B/meetingDecision: object
    /lanes/B/meetingRecord: object
    /lanes/C/meeting: object
