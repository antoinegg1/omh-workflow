    /lanes/C/meetingBrief: object
    /lanes/C/meetingSpeakers: object
    /lanes/C/meetingDecision: object
    /lanes/C/meetingRecord: object
resources:
  - path: scripts/preflight-campaign.js
    kind: script
  - path: scripts/protected-files-baseline.js
    kind: script
  - path: scripts/protected-files-check.js
    kind: script
  - path: scripts/load-campaign-state.js
    kind: script
  - path: scripts/load-skills-and-wiki.js
    kind: script
  - path: scripts/lane-utils.js
    kind: script
  - path: scripts/run-js-workflow-script.js
    kind: script
  - path: scripts/select-forced-task-workload.js
    kind: script
  - path: scripts/task-selection-guard.js
    kind: script
  - path: scripts/compact-task-context.js
    kind: script
  - path: scripts/reset-simple-plan-state.js
    kind: script
  - path: scripts/plan-review-gate.js
    kind: script
  - path: scripts/finalize-implementation-plan.js
    kind: script
  - path: scripts/implementation-precheck.js
    kind: script
  - path: scripts/validate-h800.js
    kind: script
  - path: scripts/optional-profile-h800.js
    kind: script
  - path: scripts/record-task-best.js
    kind: script
  - path: scripts/promote-and-update-leaderboard.js
    kind: script
  - path: scripts/task-local-loop-gate.js
    kind: script
  - path: scripts/next-task-or-finalize.js
    kind: script
  - path: scripts/release-worker-slot.js
    kind: script
  - path: scripts/time-budget-gate.js
    kind: script
  - path: prompts/select-task-workload.md
    kind: prompt
  - path: prompts/simple-draft-plan.md
    kind: prompt
  - path: prompts/simple-plan-review.md
    kind: prompt
  - path: prompts/simple-revise-plan.md
    kind: prompt
  - path: prompts/simple-implement-final-plan.md
    kind: prompt
  - path: prompts/correctness-repair.md
    kind: prompt
  - path: prompts/reward-hack-review.md
    kind: prompt
  - path: prompts/performance-review.md
    kind: prompt
  - path: prompts/revise-strategy.md
    kind: prompt
  - path: prompts/wiki-select-topic.md
    kind: prompt
  - path: prompts/wiki-search.md
    kind: prompt
  - path: prompts/wiki-search-review.md
    kind: prompt
  - path: scripts/wiki-write.js
    kind: script
  - path: scripts/wiki-loop-gate.js
    kind: script
  - path: prompts/meeting-brief.md
    kind: prompt
  - path: prompts/meeting-speaker.md
    kind: prompt
  - path: prompts/meeting-moderate.md
    kind: prompt
  - path: scripts/meeting-gate-sol.js
    kind: script
  - path: scripts/append-meeting-record.js
    kind: script
capabilities:
  tools:
    - bash
    - eval
    - task
    - web_search
    - fetch
  agents:
    - task
    - reviewer
  skills:
    - sol-h800-coordinator
    - sol-h800-submission
    - ncu-h800-report
    - flashkda-lessons
nodes:
  - id: preflightCampaign
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/preflight-campaign.js
    writes:
      - /campaign
      - /workerPool
  - id: protectedFilesBaseline
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/protected-files-baseline.js
    reads:
      - /campaign
    writes:
      - /protectedFiles
  - id: loadCampaignState
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-campaign-state.js
    reads:
      - /campaign
      - /workerPool
    writes:
      - /campaign
      - /leaderboard
  - id: loadSkillsAndWiki
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-skills-and-wiki.js
    reads:
      - /campaign
    writes:
      - /skills
      - /wiki
  - id: selectTaskWorkloadA
    type: agent
    agent: task
    model:
      role: coordinator
    workspaceAccess: read
    reads:
      - /campaign
      - /leaderboard
      - /wiki
      - /workerPool
    prompt:
      template:
        file: prompts/select-task-workload.md
        bindings:
          campaignTasks:
            state: /campaign/tasks
          campaignUpdates:
            state: /campaign/taskUpdates
          detailPaths:
            state: /campaign/detailPaths
          activeWorkerTasks:
            state: /campaign/taskUpdates/worker_pool
          selectionStatePath:
            inline: /lanes/A/selection
    writes:
      - /lanes/A/selection
  - id: selectForcedTaskWorkloadA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/select-forced-task-workload.js
    reads:
      - /campaign
      - /leaderboard
    writes:
      - /lanes/A/selection
  - id: taskSelectionGuardA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/task-selection-guard.js
    reads:
      - /lanes/A/selection
      - /workerPool
    writes:
      - /lanes/A/selectionGuard
      - /workerPool
  - id: loadCampaignStateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-campaign-state.js
    reads:
      - /campaign
      - /workerPool
    writes:
      - /campaign
      - /leaderboard
  - id: compactTaskContextA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/compact-task-context.js
    reads:
      - /campaign
      - /lanes/A/selection
      - /lanes/A
    writes:
      - /lanes/A/taskContext
  - id: resetSimplePlanStateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/reset-simple-plan-state.js
    reads:
      - /lanes/A/taskContext
    writes:
      - /lanes/A/planReviewMeta
      - /lanes/A/planReview
      - /lanes/A/plan
      - /lanes/A/implementationPlan
  - id: draftPlanA
    type: agent
    agent: task
    model:
      role: planner
    workspaceAccess: read
    reads:
      - /lanes/A/taskContext
    prompt:
      template:
        file: prompts/simple-draft-plan.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          planStatePath:
            inline: /lanes/A/plan
    writes:
      - /lanes/A/plan
  - id: planReviewCheckA
    type: agent
    agent: task
    model:
      role: planReviewer
    workspaceAccess: read
    reads:
      - /lanes/A/taskContext
      - /lanes/A/plan
    prompt:
      template:
        file: prompts/simple-plan-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          plan:
            state: /lanes/A/plan
          planReviewStatePath:
            inline: /lanes/A/planReview
    writes:
      - /lanes/A/planReview
  - id: planReviewGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/plan-review-gate.js
    reads:
      - /lanes/A/planReview
      - /lanes/A/planReviewMeta
      - /lanes/A/taskContext
    writes:
      - /lanes/A/planReviewMeta
  - id: revisePlanA
    type: agent
    agent: task
    model:
      role: planner
    reads:
      - /lanes/A/taskContext
      - /lanes/A/plan
      - /lanes/A/planReview
    prompt:
      template:
        file: prompts/simple-revise-plan.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          plan:
            state: /lanes/A/plan
          planReview:
            state: /lanes/A/planReview
          planStatePath:
            inline: /lanes/A/plan
    writes:
      - /lanes/A/plan
  - id: finalizeImplementationPlanA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/finalize-implementation-plan.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/plan
      - /lanes/A/planReview
      - /lanes/A/planReviewMeta
    writes:
      - /lanes/A/implementationPlan
  - id: implementCandidateA
    type: agent
    agent: task
    model:
      role: implementer
    reads:
      - /lanes/A/implementationPlan
    prompt:
      template:
        file: prompts/simple-implement-final-plan.md
        bindings:
          implementationPlan:
            state: /lanes/A/implementationPlan
          implementationStatePath:
            inline: /lanes/A/implementation
    writes:
      - /lanes/A/implementation
  - id: implementationPrecheckA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/implementation-precheck.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementation
    writes:
      - /lanes/A/implementationPrecheck
  - id: protectedFilesCheckImplementationA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/protected-files-check.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
      - /protectedFiles
      - /workerPool
    writes:
      - /lanes/A/protectedFiles
  - id: validateH800A
    type: script
    script:
      language: sh
      timeoutMs: 3600000
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/validate-h800.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
    writes:
      - /lanes/A/validation
  - id: localCorrectnessRepairA
    type: agent
    agent: task
    model:
      role: repair
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
    prompt:
      template:
        file: prompts/correctness-repair.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          validation:
            state: /lanes/A/validation
          implementationStatePath:
            inline: /lanes/A/implementation
    writes:
      - /lanes/A/implementation
  - id: rewardHackReviewA
    type: review
    agent: reviewer
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /lanes/A/taskContext
      - /lanes/A/implementationPrecheck
      - /lanes/A/validation
    prompt:
      template:
        file: prompts/reward-hack-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          precheck:
            state: /lanes/A/implementationPrecheck
          validation:
            state: /lanes/A/validation
    writes:
      - /lanes/A/rewardHackReview/verdict
    gates:
      - pass
      - revise
      - fail
    fallbackVerdict: fail
  - id: performanceReviewA
    type: agent
    agent: task
    model:
      role: reviewer
    workspaceAccess: read
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /leaderboard
    prompt:
      template:
        file: prompts/performance-review.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          validation:
            state: /lanes/A/validation
          rewardReview:
            state: /lanes/A/rewardHackReview
          leaderboard:
            state: /leaderboard
          performanceReviewStatePath:
            inline: /lanes/A/performanceReview
    writes:
      - /lanes/A/performanceReview
  - id: recordTaskBestA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/record-task-best.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
    writes:
      - /lanes/A/taskBestUpdate
  - id: optionalProfileH800A
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/optional-profile-h800.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/performanceReview
    writes:
      - /lanes/A/profile
  - id: reviseStrategyA
    type: agent
    agent: task
    model:
      role: coordinator
    reads:
      - /lanes/A/taskContext
      - /lanes/A/performanceReview
    prompt:
      template:
        file: prompts/revise-strategy.md
        bindings:
          taskContext:
            state: /lanes/A/taskContext
          performanceReview:
            state: /lanes/A/performanceReview
          revisionStatePath:
            inline: /lanes/A/revision
    writes:
      - /lanes/A/revision
  - id: protectedFilesCheckRevisionA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/protected-files-check.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/revision
      - /protectedFiles
      - /workerPool
    writes:
      - /lanes/A/protectedFiles
  - id: promoteAndUpdateLeaderboardA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/promote-and-update-leaderboard.js
    reads:
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
    writes:
      - /leaderboard
      - /lanes/A/leaderboardUpdate
  - id: taskLocalLoopGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/task-local-loop-gate.js
    reads:
      - /campaign
      - /lanes/A/taskContext
      - /lanes/A/validation
      - /lanes/A/rewardHackReview
      - /lanes/A/performanceReview
      - /lanes/A/leaderboardUpdate
    writes:
      - /campaign
      - /lanes/A/localLoop
  - id: releaseWorkerSlotA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/release-worker-slot.js
    reads:
      - /lanes/A
      - /workerPool
    writes:
      - /lanes/A/release
      - /workerPool
  - id: nextTaskOrFinalizeA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/next-task-or-finalize.js
    reads:
      - /campaign
      - /leaderboard
      - /lanes/A
    writes:
      - /campaign
  - id: timeBudgetGateA
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/time-budget-gate.js
    reads:
      - /campaign
      - /lanes/A
    writes:
      - /campaign
  - id: selectTaskWorkloadB
    type: agent
    agent: task
    model:
      role: coordinator
    workspaceAccess: read
    reads:
      - /campaign
      - /leaderboard
      - /wiki
      - /workerPool
    prompt:
      template:
        file: prompts/select-task-workload.md
        bindings:
          campaignTasks:
            state: /campaign/tasks
          campaignUpdates:
            state: /campaign/taskUpdates
          detailPaths:
            state: /campaign/detailPaths
          activeWorkerTasks:
            state: /campaign/taskUpdates/worker_pool
          selectionStatePath:
            inline: /lanes/B/selection
    writes:
      - /lanes/B/selection
  - id: selectForcedTaskWorkloadB
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/select-forced-task-workload.js
    reads:
      - /campaign
      - /leaderboard
    writes:
      - /lanes/B/selection
  - id: taskSelectionGuardB
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/task-selection-guard.js
    reads:
      - /lanes/B/selection
      - /workerPool
    writes:
      - /lanes/B/selectionGuard
      - /workerPool
  - id: loadCampaignStateB
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/load-campaign-state.js
    reads:
      - /campaign
      - /workerPool
    writes:
      - /campaign
      - /leaderboard
  - id: compactTaskContextB
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/compact-task-context.js
    reads:
      - /campaign
      - /lanes/B/selection
      - /lanes/B
    writes:
      - /lanes/B/taskContext
  - id: resetSimplePlanStateB
    type: script
    script:
      language: sh
      inline: |-
        bun "$OMP_WORKFLOW_RESOURCE_DIR/scripts/run-js-workflow-script.js" scripts/reset-simple-plan-state.js
    reads:
      - /lanes/B/taskContext
    writes:
      - /lanes/B/planReviewMeta
      - /lanes/B/planReview
      - /lanes/B/plan
      - /lanes/B/implementationPlan
  - id: draftPlanB
    type: agent
    agent: task
    model:
      role: planner
    workspaceAccess: read
    reads:
      - /lanes/B/taskContext
    prompt:
      template:
        file: prompts/simple-draft-plan.md
        bindings:
          taskContext:
            state: /lanes/B/taskContext
          planStatePath:
            inline: /lanes/B/plan
    writes:
